# =============================================================================
# Wallets
# =============================================================================
# PRIVATE_KEY pays for and signs deployment/admin transactions.
# The default below is the first Anvil account — replace before deploying anywhere
# but a local fork.
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Minter key used by 03_MintTokens.s.sol — should be granted MINTER_ROLE first.
MINTER_PRIVATE_KEY=0x59c6995e998f97a5a0044966f0945389dc9e86dae88c7a8412f4603b6b78690d

# =============================================================================
# RPC endpoints
# =============================================================================
# Matches the [rpc_endpoints] block in foundry.toml. Set the ones you plan to use.
RPC_URL="http://127.0.0.1:8545"
ETHEREUM_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
OPTIMISM_SEPOLIA_RPC_URL=
AVALANCHE_FUJI_RPC_URL=

# =============================================================================
# Block explorer API keys (only needed for `forge verify-contract`)
# =============================================================================
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
BASESCAN_API_KEY=
OPTIMISTIC_ETHERSCAN_API_KEY=
SNOWTRACE_API_KEY=

# =============================================================================
# Token defaults (override HelperConfig.NetworkConfig values)
# =============================================================================
TOKEN_NAME="Future Proof USD"
TOKEN_SYMBOL="FPUSD"

# =============================================================================
# Demo / walkthrough addresses
# =============================================================================
# These are Anvil dev accounts wired up for the README walkthrough. Replace with
# real testnet addresses you control before running against a public testnet.
MINTER_ADDRESS=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
ALICE_ADDRESS=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC
ALICE_PRIVATE_KEY=0x5de4111afa1a4b94908f83103eb1f1706367c2e68ca870fc3fb9a804cdab365a
BOB_ADDRESS=0x15d34AAf54267DB7D7c367839AAf71A00a2C6A65
SANCTIONED_ADDRESS=0x90F79bf6EB2c4f870365E785982E1f101E93b906
SANCTIONED_PRIVATE_KEY=0x7c852118294e51e653712a81e05800f419141751be58f605c371e15141b007a6

# Script knobs
ROLE_NAME=MINTER
ROLE_RECIPIENT=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
ROLE_ACTION=grant
MINT_RECIPIENT=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC
MINT_AMOUNT=20000000000
MAX_TRANSFER_AMOUNT=10000000000

# =============================================================================
# Exported after each step in the walkthrough — leave as zeros until you run
# the scripts and copy the resulting addresses back in.
# =============================================================================
POLICY_ENGINE_ADDRESS=0x0000000000000000000000000000000000000000
TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
RBAC_POLICY_ADDRESS=0x0000000000000000000000000000000000000000
PAUSE_POLICY_ADDRESS=0x0000000000000000000000000000000000000000
TRANSFER_EXTRACTOR_ADDRESS=0x0000000000000000000000000000000000000000
SANCTIONS_LIST_ADDRESS=0x0000000000000000000000000000000000000000
SANCTIONS_POLICY_ADDRESS=0x0000000000000000000000000000000000000000
MAX_POLICY_ADDRESS=0x0000000000000000000000000000000000000000
